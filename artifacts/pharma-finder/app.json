{
  "expo": {
    "name": "DEWAYA | أدْواَيَ",
    "slug": "dewaya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dewaya",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D9488"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dewaya.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "يحتاج التطبيق إلى الكاميرا لتصوير علبة الدواء / L'application a besoin de la caméra pour photographier la boîte du médicament",
        "NSPhotoLibraryUsageDescription": "يحتاج التطبيق إلى معرض الصور لاختيار صورة علبة الدواء / L'application a besoin de la galerie pour sélectionner une image",
        "NSPhotoLibraryAddUsageDescription": "لحفظ الصور / Pour enregistrer des images",
        "NSUserNotificationUsageDescription": "للتنبيه عند العثور على الدواء القريب منك / Pour vous alerter quand le médicament est trouvé",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.dewaya.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0D9488"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "يحتاج التطبيق إلى معرض الصور / L'application a besoin de la galerie",
          "cameraPermission": "يحتاج التطبيق إلى الكاميرا / L'application a besoin de la caméra"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "يحتاج التطبيق إلى الكاميرا لتصوير علبة الدواء / L'application a besoin de la caméra pour photographier la boîte du médicament"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0D9488",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "DEWAYA • أدْواَيَ"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
